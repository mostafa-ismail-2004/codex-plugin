{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/hooks/observe.sh pre",
            "statusMessage": "Recording Codex Plugin observation"
          },
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/hooks/sync-config.sh",
            "statusMessage": "Checking Codex Plugin config backup"
          }
        ]
      },
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/hooks/suggest-compact.sh",
            "statusMessage": "Checking context checkpoint"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/hooks/observe.sh post",
            "statusMessage": "Recording Codex Plugin observation"
          }
        ]
      }
    ]
  }
}
